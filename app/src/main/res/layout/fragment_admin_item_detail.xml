<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER TOOLBAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#F5F0EB"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#1C2B4A" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Detail Item"
                    android:textColor="#1C2B4A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Tersedia"
                    android:textColor="#16A34A"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- FOTO ITEM -->
            <ImageView
                android:id="@+id/ivDetailPhoto"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#E5E7EB"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_banner_explore" />

            <!-- INFO UTAMA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Sony Alpha A7 III"
                        android:textColor="#1C2B4A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="FOTOGRAFI"
                        android:textAllCaps="true"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDetailPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rp 85.000/hari"
                            android:textColor="#1C2B4A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDetailCondition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_bar"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Sangat Baik"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F3F4F6" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL DISEWA" android:textAllCaps="true" android:textColor="#9CA3AF" android:textSize="10sp" />
                            <TextView android:id="@+id/tvDetailRentCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24 kali" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENDAPATAN" android:textAllCaps="true" android:textColor="#9CA3AF" android:textSize="10sp" />
                            <TextView android:id="@+id/tvDetailIncome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 2,04jt" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- INFO PEMILIK -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="PEMILIK ITEM"
                        android:textAllCaps="true"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/ownerAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#1C2B4A">
                            <TextView
                                android:id="@+id/tvOwnerInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="A"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvOwnerName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ahmad Rizky P" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvOwnerEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ahmadricky@apps.ipb.ac.id" android:textColor="#9CA3AF" android:textSize="12sp" />
                        </LinearLayout>

                        <ImageButton
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_stat_bar"
                            android:padding="8dp"
                            android:src="@drawable/ic_chat"
                            app:tint="#1C2B4A" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DESKRIPSI -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="DESKRIPSI"
                        android:textAllCaps="true"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="Spesifikasi, kelengkapan, syarat sewa..."
                        android:textColor="#6B7280"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- RIWAYAT RENTAL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="RIWAYAT RENTAL" android:textAllCaps="true" android:textColor="#9CA3AF" android:textSize="10sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lihat semua" android:textColor="#1C2B4A" android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Dummy History 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#0F6E56" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dimas Pratama" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20 Okt 2023" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 170.000" android:textColor="#1C2B4A" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

                    <!-- Dummy History 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#DC2626" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Siti Nurhaliza" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 Okt 2023" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 85.000" android:textColor="#1C2B4A" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM ACTIONS -->
    <LinearLayout
        android:id="@+id/llActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="14dp">

        <Button
            android:id="@+id/btnBlokirItem"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_inactive_admin"
            android:backgroundTint="@android:color/transparent"
            android:text="Blokir Item"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            app:strokeColor="#EF4444"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnEditItem"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_active_admin"
            android:text="Edit Item"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnAktifkanItem"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_chip_active_admin"
            android:backgroundTint="#16A34A"
            android:text="Aktifkan Item"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>