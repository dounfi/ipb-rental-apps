<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER TOOLBAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#F5F0EB"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#1C2B4A" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Detail Pengaduan"
                    android:textColor="#1C2B4A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_red"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Baru"
                    android:textColor="#DC2626"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- SECTION 1: INFO PENGADUAN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/flDetailIconBg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_pengaduan_icon_red">

                            <ImageView
                                android:id="@+id/ivDetailCategoryIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_items"
                                app:tint="#EF4444" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDetailKategori"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kondisi Item"
                                android:textColor="#1C2B4A"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailWaktu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8 jam lalu"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F3F4F6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="LAPORAN"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#F9FAFB"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:id="@+id/tvDetailIsiPengaduan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="5dp"
                            android:padding="14dp"
                            android:text="Isi pengaduan lengkap..."
                            android:textColor="#4B5563"
                            android:textSize="13sp" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 2: PIHAK TERLIBAT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="PIHAK TERLIBAT"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <!-- Pelapor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#0F6E56">
                            <TextView
                                android:id="@+id/tvPelaporInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="A"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:id="@+id/tvPelaporName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ahmad Sony" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:background="@drawable/bg_badge_blue_light" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:text="Pelapor" android:textColor="#1D4ED8" android:textSize="9sp" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvPelaporEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="sony@apps.ipb.ac.id" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>

                        <ImageButton
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_stat_bar"
                            android:padding="8dp"
                            android:src="@drawable/ic_chat"
                            app:tint="#1C2B4A" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="10dp" android:background="#F3F4F6" />

                    <!-- Terlapor (Pemilik Item) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#1C2B4A">
                            <TextView
                                android:id="@+id/tvTerlaporInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="O"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:id="@+id/tvTerlaporName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pemilik Item" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:background="#FEE2E2" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:text="Terlapor" android:textColor="#DC2626" android:textSize="9sp" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvTerlaporEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="owner@apps.ipb.ac.id" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>

                        <ImageButton
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_stat_bar"
                            android:padding="8dp"
                            android:src="@drawable/ic_chat"
                            app:tint="#1C2B4A" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 3: ITEM TERKAIT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="ITEM TERKAIT"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivDetailItemPhoto"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="#E8EDF4"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_banner_explore" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDetailItemName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sony WH-1000XM5"
                                android:textColor="#1C2B4A"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 30.000/hari · 01 Mar - 03 Mar"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 4: CATATAN ADMIN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="CATATAN ADMIN"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/etAdminNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quote_block"
                        android:gravity="top"
                        android:hint="Tambahkan catatan penanganan..."
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:padding="12dp"
                        android:textColor="#1C2B4A"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM ACTIONS -->
    <LinearLayout
        android:id="@+id/llBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/llBaruActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnTolak"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_inactive_admin"
                android:backgroundTint="@android:color/transparent"
                android:text="Tolak"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                app:strokeColor="#EF4444"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btnProsesSekarang"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:background="@drawable/bg_chip_active_admin"
                android:text="Proses Sekarang"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llDiprosesActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnHubungiPihak"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_inactive_admin"
                android:backgroundTint="@android:color/transparent"
                android:text="Hubungi Pihak"
                android:textAllCaps="false"
                android:textColor="#1C2B4A"
                app:strokeColor="#1C2B4A"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btnTandaiSelesai"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_active_admin"
                android:backgroundTint="#16A34A"
                android:text="Tandai Selesai"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/btnTutupDetail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_chip_inactive_admin"
            android:backgroundTint="#F5F0EB"
            android:text="Tutup"
            android:textAllCaps="false"
            android:textColor="#6B7280"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>