<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- HANDLE BAR -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#D1D5DB" />

    <!-- USER HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/avatarLarge"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_avatar_circle">

            <TextView
                android:id="@+id/tvInitialLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ahmad Rizky P"
                android:textColor="#1C2B4A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ahmadricky@apps.ipb.ac.id"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- BADGES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDetailRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Pemilik"
            android:textColor="#1D4ED8"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvDetailStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Aktif"
            android:textColor="#16A34A"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:background="#F3F4F6" />

    <!-- INFO GRID -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvDetailNim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G64123456"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bergabung"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Mar 2024"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Rental"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 kali"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Item"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 item"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>
    </GridLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#F3F4F6" />

    <!-- ACTIONS -->
    <Button
        android:id="@+id/btnToggleStatus"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_chip_inactive_admin"
        android:backgroundTint="@android:color/transparent"
        android:text="Blokir User"
        android:textAllCaps="false"
        android:textColor="#EF4444"
        app:strokeColor="#EF4444"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/btnDismiss"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Tutup"
        android:textColor="#6B7280" />

</LinearLayout>