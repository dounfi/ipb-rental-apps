<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle_bar" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checkout"
        android:textColor="#1C2B4A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCheckoutItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="MacBook Pro 14\"
        android:textColor="#9CA3AF"
        android:textSize="13sp" />

    <!-- CARD ITEM -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#F5F0EB"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCheckoutItem"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_logo_placeholder"
                android:background="@drawable/bg_input_field" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCheckoutItemTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MacBook Pro 14\"
                    android:textColor="#1C2B4A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCheckoutItemSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 120.000 / hari • Elektronik"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- TANGGAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="TANGGAL MULAI"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMulaiCheckout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#F5F0EB"
                android:drawableEnd="@drawable/ic_rentals"
                android:drawablePadding="8dp"
                android:drawableTint="#9CA3AF"
                android:focusable="false"
                android:padding="10dp"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="TANGGAL SELESAI"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSelesaiCheckout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#F5F0EB"
                android:drawableEnd="@drawable/ic_rentals"
                android:drawablePadding="8dp"
                android:drawableTint="#9CA3AF"
                android:focusable="false"
                android:padding="10dp"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- RINGKASAN BIAYA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Harga sewa"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvHargaSewaSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 120.000 × 1 hari"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Durasi"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDurasiSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 hari"
                android:textColor="#1C2B4A"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#F3F4F6" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Bayar"
                android:textColor="#1C2B4A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotalBayarSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 120.000"
                android:textColor="#1C2B4A"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPilihPembayaran"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Pilih Pembayaran →"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:backgroundTint="#1C2B4A"
        app:cornerRadius="14dp" />

    <TextView
        android:id="@+id/btnBatalCheckout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Batal"
        android:textColor="#6B7280"
        android:textSize="14sp" />

</LinearLayout>
