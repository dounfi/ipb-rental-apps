<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER TOOLBAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#F5F0EB"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#1C2B4A" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Detail Transaksi"
                    android:textColor="#1C2B4A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Aktif"
                    android:textColor="#16A34A"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- SECTION 1: BOOKING ID & STATUS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No. Booking"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvBookingId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#IPB2026001"
                            android:textColor="#1C2B4A"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Metode Bayar"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvMetodeBayar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_dark"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="QRIS / M-Banking"
                            android:textColor="#1C2B4A"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 2: INFO ITEM -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="ITEM DISEWA"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivDetailItemPhoto"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="#E8EDF4"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_banner_explore" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDetailItemName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MacBook Pro 14"
                                android:textColor="#1C2B4A"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailCategory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elektronik"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailPricePerDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Rp 60.000/hari"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 3: INFO PENYEWA & PEMILIK -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="PIHAK TERLIBAT"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <!-- Penyewa -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/penyewaAvatar"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#0F6E56">
                            <TextView
                                android:id="@+id/tvPenyewaInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="D"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:id="@+id/tvPenyewaName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dimas Pratama" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:background="@drawable/bg_badge_blue_light" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:text="Penyewa" android:textColor="#1D4ED8" android:textSize="10sp" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvPenyewaEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="dimas@apps.ipb.ac.id" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>

                        <ImageButton
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_stat_bar"
                            android:padding="8dp"
                            android:src="@drawable/ic_chat"
                            app:tint="#1C2B4A" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="8dp" android:background="#F3F4F6" />

                    <!-- Pemilik -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/ownerAvatar"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#1C2B4A">
                            <TextView
                                android:id="@+id/tvOwnerInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="A"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:id="@+id/tvOwnerName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ahmad Rizky" android:textColor="#1C2B4A" android:textSize="13sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:background="#D1FAE5" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:text="Pemilik" android:textColor="#065F46" android:textSize="10sp" />
                            </LinearLayout>
                            <TextView android:id="@+id/tvOwnerEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ahmadricky@apps.ipb.ac.id" android:textColor="#9CA3AF" android:textSize="11sp" />
                        </LinearLayout>

                        <ImageButton
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_stat_bar"
                            android:padding="8dp"
                            android:src="@drawable/ic_chat"
                            app:tint="#1C2B4A" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 4: RINCIAN BIAYA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="RINCIAN BIAYA"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tanggal Mulai" android:textColor="#9CA3AF" android:textSize="12sp" /><TextView android:id="@+id/tvDetailStartDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03 Mar 2026" android:textColor="#1C2B4A" android:textSize="12sp" /></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tanggal Selesai" android:textColor="#9CA3AF" android:textSize="12sp" /><TextView android:id="@+id/tvDetailEndDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="06 Mar 2026" android:textColor="#1C2B4A" android:textSize="12sp" /></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Durasi" android:textColor="#9CA3AF" android:textSize="12sp" /><TextView android:id="@+id/tvDetailDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3 hari" android:textColor="#1C2B4A" android:textSize="12sp" /></LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="10dp" android:background="#F3F4F6" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Harga" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" /><TextView android:id="@+id/tvDetailTotalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 180.000" android:textColor="#1C2B4A" android:textSize="16sp" android:textStyle="bold" /></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DP Dibayar (50%)" android:textColor="#9CA3AF" android:textSize="12sp" /><TextView android:id="@+id/tvDetailDpPaid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 90.000" android:textColor="#16A34A" android:textSize="12sp" /></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sisa Pembayaran" android:textColor="#9CA3AF" android:textSize="12sp" /><TextView android:id="@+id/tvDetailRemaining" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 90.000" android:textColor="#F59E0B" android:textSize="12sp" /></LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 5: TIMELINE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="TIMELINE"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textAllCaps="true" />

                    <!-- Step 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#1C2B4A" />
                            <View android:layout_width="2dp" android:layout_height="24dp" android:background="#1C2B4A" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Booking Dibuat" android:textColor="#1C2B4A" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="01 Mar 2026, 14:20" android:textColor="#9CA3AF" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center_horizontal">
                            <View android:id="@+id/dotStep2" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#16A34A" />
                            <View android:id="@+id/lineStep2" android:layout_width="2dp" android:layout_height="24dp" android:background="#16A34A" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvStep2Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DP Dikonfirmasi" android:textColor="#1C2B4A" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvStep2Date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="01 Mar 2026, 15:45" android:textColor="#9CA3AF" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 3 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center_horizontal">
                            <View android:id="@+id/dotStep3" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#1C2B4A" />
                            <View android:id="@+id/lineStep3" android:layout_width="2dp" android:layout_height="24dp" android:background="#E5E7EB" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvStep3Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Item Diserahkan ke Penyewa" android:textColor="#1C2B4A" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvStep3Date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03 Mar 2026, 10:00" android:textColor="#9CA3AF" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 4 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center_horizontal">
                            <View android:id="@+id/dotStep4" android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_avatar_circle" android:backgroundTint="#E5E7EB" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvStep4Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rental Selesai" android:textColor="#6B7280" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM ACTIONS -->
    <LinearLayout
        android:id="@+id/llBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="14dp">

        <Button
            android:id="@+id/btnActionPrimary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_active_admin"
            android:text="Action"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnActionSecondary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_inactive_admin"
            android:backgroundTint="@android:color/transparent"
            android:text="Action"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            app:strokeColor="#EF4444"
            app:strokeWidth="1dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnActionFull"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_chip_active_admin"
            android:text="Action"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>