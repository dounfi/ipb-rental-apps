<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Image / Illustration -->
    <ImageView
        android:id="@+id/iv_illustration"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:layout_marginTop="40dp"
        android:adjustViewBounds="true"
        android:scaleType="centerInside"
        android:src="@drawable/on_boarding_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Rating/Security Status Indicators -->
    <LinearLayout
        android:id="@+id/ll_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_illustration">

        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" />
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" />
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" />
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" />
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_rating_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="4.9 • 12 ulasan"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_status" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="64dp"
        android:layout_marginTop="20dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/tv_rating_count" />

    <!-- Text Block -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="Aman &amp;\nTerpercaya 🔒"
        android:textColor="@color/navy_blue"
        android:textSize="32sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="16dp"
        android:gravity="start"
        android:lineSpacingExtra="4dp"
        android:text="Semua pengguna diverifikasi mahasiswa IPB. Deposit tersimpan aman sampai transaksi benar-benar selesai."
        android:textColor="#888888"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

</androidx.constraintlayout.widget.ConstraintLayout>