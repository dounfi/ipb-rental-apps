<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 1. HERO HEADER (Fixed) -->
    <LinearLayout
        android:id="@+id/hero_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A5C"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Laporan &amp; Pengaduan"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.8"
            android:text="Ada masalah? Admin siap membantu dalam 1×24 jam kerja."
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 2. TAB LAYOUT (Styled to match Rental Saya toggle) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_report"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_toggle_container"
        app:layout_constraintTop_toBottomOf="@id/hero_header"
        app:tabIndicatorGravity="stretch"
        app:tabIndicatorHeight="40dp"
        app:tabIndicator="@drawable/bg_toggle_active"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#6B7280"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@android:color/transparent"
        app:tabIndicatorFullWidth="true"
        app:tabTextAppearance="@android:style/TextAppearance.Small"
        android:padding="4dp"/>

    <!-- 3. VIEW PAGER -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_report"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_layout_report" />

</androidx.constraintlayout.widget.ConstraintLayout>
