<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- FIXED HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kelola Item"
                android:textColor="#1C2B4A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnTambahItem"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip_active_admin"
                android:padding="8dp"
                android:src="@drawable/ic_add"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- STATISTIK BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_stat_bar"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="84" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Item" android:textColor="#9CA3AF" android:textSize="9sp" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="24dp" android:layout_gravity="center_vertical" android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="61" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tersedia" android:textColor="#9CA3AF" android:textSize="9sp" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="24dp" android:layout_gravity="center_vertical" android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sedang Disewa" android:textColor="#9CA3AF" android:textSize="9sp" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="24dp" android:layout_gravity="center_vertical" android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="#1C2B4A" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Diblokir" android:textColor="#9CA3AF" android:textSize="9sp" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="24dp" android:layout_gravity="center_vertical" android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4.5★" android:textColor="#F59E0B" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg Rating" android:textColor="#9CA3AF" android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- SEARCH BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_stat_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_search"
            app:tint="#9CA3AF" />

        <EditText
            android:id="@+id/etSearchItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Cari item, kategori, pemilik..."
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#1C2B4A"
            android:textColorHint="#9CA3AF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- FILTER CHIPS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipSemua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_active_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Semua (84)"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFotografi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Fotografi"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipElektronik"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Elektronik"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Audio"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipDrone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Drone"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipOlahraga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Olahraga"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipAkademik"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive_admin"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="Akademik"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:padding="12dp"
        android:paddingBottom="80dp" />

</LinearLayout>