<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- FOTO HEADER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/ivItemImage"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_logo_placeholder" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:src="@drawable/ic_cancel"
                        app:tint="#1C2B4A" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_margin="12dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnBookmark"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:src="@drawable/ic_heart"
                        app:tint="#1C2B4A" />

                    <ImageButton
                        android:id="@+id/btnShare"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:src="@drawable/ic_explore"
                        app:tint="#1C2B4A" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_status_aktif"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="Tersedia"
                    android:textColor="#16A34A"
                    android:textSize="13sp" />
            </FrameLayout>

            <!-- INFO PRODUK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:letterSpacing="0.1"
                    android:text="KATEGORI"
                    android:textAllCaps="true"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvItemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Nama Item"
                    android:textColor="#1C2B4A"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPricePerDay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#1C2B4A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="/hari"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F3F4F6" />

                <!-- INFO PEMILIK -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Pemilik"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:src="@drawable/ic_profile"
                        app:tint="#1C2B4A" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvOwnerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dimas Pratama"
                            android:textColor="#1C2B4A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pemilik item"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnChatOwner"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_input_cream"
                        android:padding="8dp"
                        android:src="@drawable/ic_email"
                        app:tint="#1C2B4A" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F3F4F6" />

                <!-- DESKRIPSI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Deskripsi"
                    android:textColor="#1C2B4A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="3"
                    android:text="Deskripsi produk akan muncul di sini."
                    android:textColor="#6B7280"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvReadMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Baca selengkapnya"
                    android:textColor="#1C2B4A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F3F4F6" />

                <!-- DURASI SEWA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Pilih Durasi Sewa"
                    android:textColor="#1C2B4A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="MULAI"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <EditText
                                android:id="@+id/etTanggalMulai"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input_field"
                                android:focusable="false"
                                android:hint="DD/MM/YYYY"
                                android:inputType="date"
                                android:padding="12dp"
                                android:singleLine="true"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_rentals"
                                app:tint="#9CA3AF" />
                        </FrameLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="SELESAI"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <EditText
                                android:id="@+id/etTanggalSelesai"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input_field"
                                android:focusable="false"
                                android:hint="DD/MM/YYYY"
                                android:inputType="date"
                                android:padding="12dp"
                                android:singleLine="true"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_rentals"
                                app:tint="#9CA3AF" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- RINGKASAN HARGA -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#F5F0EB"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Durasi Sewa"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvDurasiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="- hari"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total Harga"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvTotalHargaValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp -"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="8dp"
                            android:background="#E5E7EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="WAJIB DP (50%)"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWajibDPValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp -"
                                android:textColor="#1C2B4A"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <CheckBox
                            android:id="@+id/cbSyarat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:buttonTint="#1C2B4A"
                            android:text="Saya menyetujui syarat &amp; ketentuan penyewaan"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total DP"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvTotalDPBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp -"
                android:textColor="#1C2B4A"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLanjutBayar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:text="Lanjut Bayar →"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#1C2B4A"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
